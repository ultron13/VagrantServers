Vagrant.configure("2") do |config|

  # Base settings
  config.vm.boot_timeout = 600
  config.ssh.username = "vagrant"
  config.ssh.insert_key = false

  # Hostmanager
  config.hostmanager.enabled = true 
  config.hostmanager.manage_host = true
  config.hostmanager.manage_guest = true

  # Global libvirt settings
  config.vm.provider :libvirt do |libvirt|
    libvirt.nic_model_type = "virtio"
    libvirt.machine_type   = "pc"     # safer default than q35
    libvirt.driver         = "qemu"
  end

  ############################
  # Example VM: DB01
  ############################
  config.vm.define "db01" do |db01|
    db01.vm.box = "eurolinux-vagrant/centos-stream-9"
    db01.vm.box_version = "9.0.43"
    db01.vm.hostname = "db01"

    # Use static IP instead of DHCP
    db01.vm.network "private_network", ip: "192.168.56.10"

    db01.vm.provider :libvirt do |libvirt|
      libvirt.memory = 1024
      libvirt.cpus = 1
    end
  end

  ############################
  # Example VM: APP01
  ############################
  config.vm.define "app01" do |app01|
    app01.vm.box = "eurolinux-vagrant/centos-stream-9"
    app01.vm.box_version = "9.0.43"
    app01.vm.hostname = "app01"

    app01.vm.network "private_network", ip: "192.168.56.11"

    app01.vm.provider :libvirt do |libvirt|
      libvirt.memory = 2048
      libvirt.cpus = 2
    end
  end

  ############################
  # Example VM: WEB01
  ############################
  config.vm.define "web01" do |web01|
    web01.vm.box = "eurolinux-vagrant/centos-stream-9"
    web01.vm.box_version = "9.0.43"
    web01.vm.hostname = "web01"

    web01.vm.network "private_network", ip: "192.168.56.12"

    web01.vm.provider :libvirt do |libvirt|
      libvirt.memory = 1024
      libvirt.cpus = 1
    end
  end

end